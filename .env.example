# ARPO Studio production/development environment

# General paths
ARPO_WORKSPACE_ROOT=/app
ARPO_DATA_DIR=/app/data
ARPO_EXAMPLES_DIR=/app/examples
ARPO_FRONTEND_DIST=/app/frontend/dist

# Security
# Comma-separated API keys. Leave empty for local-only development.
ARPO_API_KEYS=
ARPO_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
ARPO_RATE_LIMIT_PER_MINUTE=120
ARPO_MAX_UPLOAD_BYTES=10485760

# Jobs and saved runs
ARPO_JOB_WORKERS=2
ARPO_RUN_STORE=/app/data/arpo-runs.sqlite

# Retrieval and indexing
ARPO_EMBEDDING_BACKEND=hash
ARPO_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
ARPO_VECTOR_INDEX_DIR=/app/data/vector-indexes
ARPO_VECTOR_CACHE=1

# Frontend builds can pass this through if API-key auth is enabled.
VITE_ARPO_API_KEY=
